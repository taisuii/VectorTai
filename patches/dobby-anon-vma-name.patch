diff --git a/source/Backend/UserMode/UnifiedInterface/platform-posix.cc b/source/Backend/UserMode/UnifiedInterface/platform-posix.cc
index 5894ae8..b7718fc 100644
--- a/source/Backend/UserMode/UnifiedInterface/platform-posix.cc
+++ b/source/Backend/UserMode/UnifiedInterface/platform-posix.cc
@@ -17,6 +17,16 @@
 #include <sys/time.h>
 #include <sys/types.h>
 #include <sys/syscall.h>
+#include <sys/prctl.h>
+
+// Anti-detection: label executable trampoline arenas so /proc/pid/maps shows
+// them as ART's own JIT code cache instead of a nameless anonymous X region.
+#ifndef PR_SET_VMA
+#define PR_SET_VMA 0x53564d41
+#endif
+#ifndef PR_SET_VMA_ANON_NAME
+#define PR_SET_VMA_ANON_NAME 0
+#endif
 
 #if defined(__APPLE__) || defined(__DragonFly__) || defined(__FreeBSD__) || defined(__NetBSD__) || defined(__OpenBSD__)
 #include <sys/sysctl.h> // NOLINT, for sysctl
@@ -137,6 +147,13 @@ void *OSMemory::Allocate(size_t size, MemoryPermission access, void *fixed_addre
   if (result == MAP_FAILED)
     return nullptr;
 
+  // Disguise executable trampoline memory as the runtime's JIT code cache, so a
+  // detector walking /proc/self/maps cannot flag it as unexpected anonymous
+  // executable memory (every ART process legitimately owns such a region).
+  if (prot & PROT_EXEC) {
+    prctl(PR_SET_VMA, PR_SET_VMA_ANON_NAME, result, size, "dalvik-jit-code-cache");
+  }
+
   return result;
 }
 
